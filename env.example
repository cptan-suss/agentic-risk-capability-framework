# OpenAI API Key for LiteLLM integration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: You can also use other LLM providers supported by LiteLLM
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# Azure OpenAI Configuration (Optional)
# When using Azure, set the ARC_LLM_* variables below to azure/<your-deployment-name>
# AZURE_API_KEY=your_azure_key_here
# AZURE_API_BASE=https://your-resource.openai.azure.com/

# ARC LLM Model Configuration (Optional)
# These variables control which LLM models are used for different analysis tasks.
# If not set, the defaults shown below will be used.
# ARC_LLM_CAPABILITY_MODEL=gpt-4o        # For capability analysis
# ARC_LLM_RISK_MODEL=gpt-5               # For risk assessment
# ARC_LLM_REPO_MODEL=gpt-5.1-codex       # For repository analysis
# ARC_LLM_DESCRIPTION_MODEL=gpt-4o-mini  # For description generation